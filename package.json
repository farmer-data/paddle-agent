{
  "name": "paddle-agent",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "dev:trigger": "trigger dev start --env-file .env",
    "smoke:chat": "node --env-file=.env --import tsx scripts/smoke-chat.ts",
    "smoke:trip": "node --env-file=.env --import tsx scripts/smoke-trip.ts",
    "smoke:compare": "node --env-file=.env --import tsx scripts/smoke-compare.ts",
    "ingest:once": "node --env-file=.env --import tsx scripts/ingest-once.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.0",
    "@ai-sdk/react": "^3.0.0",
    "@clickhouse/client": "^1.14.0",
    "@trigger.dev/sdk": "^4.5.4",
    "ai": "^6.0.0",
    "next": "^16.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "trigger.dev": "^4.5.4",
    "tsx": "^4.23.1",
    "typescript": "^5.0.0",
    "vitest": "^4.1.10"
  }
}
