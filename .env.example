# Trigger.dev (use the project created for this workspace)
TRIGGER_SECRET_KEY=tr_dev_...

# OpenAI model access
OPENAI_API_KEY=

# ClickHouse Cloud connection; create separate ingest and read-only credentials in production
CLICKHOUSE_URL=https://your-instance.clickhouse.cloud:8443
CLICKHOUSE_USERNAME=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=default

# Optional: enables watch-change email notifications
RESEND_API_KEY=
ALERT_FROM_EMAIL=KayakGuide <alerts@example.com>
